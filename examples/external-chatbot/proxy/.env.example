# Copy to .env and fill in, then start with:  npm start
# (These are read from the process environment. Load them however you like — e.g.
#  `export $(grep -v '^#' .env | xargs)` on bash, or a tool like dotenv/direnv.)

# Your Salesforce My Domain / instance login URL — scheme + host only, no trailing path.
SF_LOGIN_URL=https://YOURDOMAIN.my.salesforce.com

# Connected App credentials (Consumer Key / Consumer Secret).
# The Connected App must have "Enable Client Credentials Flow" checked and its
# Run-As user set to the integration user (Manage -> Edit Policies).
SF_CLIENT_ID=your_consumer_key
SF_CLIENT_SECRET=your_consumer_secret

# Port the proxy (and widget) are served on.
PORT=8080
